# MeshCoverage — Environment Configuration
# Copy to .env and modify the values

# ── Web Server ──────────────────────────────────────────────────────────────
MESHCOVERAGE_HOST=0.0.0.0
MESHCOVERAGE_PORT=8000
MESHCOVERAGE_SECRET_KEY=change-this-secret-key  # python -c "import secrets; print(secrets.token_hex())"
MESHCOVERAGE_LOG_LEVEL=INFO

# ── Data Directory ──────────────────────────────────────────────────────────
MESHCOVERAGE_DATA_DIR=./data

# ── MQTT ────────────────────────────────────────────────────────────────────
MESHCOVERAGE_MQTT_ENABLED=false
MESHCOVERAGE_MQTT_BROKER=mqtt.meshtastic.org
MESHCOVERAGE_MQTT_PORT=1883
MESHCOVERAGE_MQTT_TOPIC=msh/#
MESHCOVERAGE_MQTT_TLS=false
# MESHCOVERAGE_MQTT_USERNAME=user
# MESHCOVERAGE_MQTT_PASSWORD=pass

# ── Direct Connection ─────────────────────────────────────────────────────
MESHCOVERAGE_DIRECT_ENABLED=false
MESHCOVERAGE_DIRECT_HOST=192.168.1.100
MESHCOVERAGE_DIRECT_PORT=4403

# ── Computation Scheduling ──────────────────────────────────────────────────
# Cron format: min hour day month weekday
MESHCOVERAGE_COMPUTE_SCHEDULE=0 3 * * *

# ── DEM and Coverage Calculation ─────────────────────────────────────────────
MESHCOVERAGE_DEM_DIR=./data/dem

# DEM grid resolution in metres. Controls the density of terrain-profile
# sample points. The engine applies adaptive coarsening for long-range nodes
# automatically (this value acts as the minimum / near-field resolution).
#   100m — recommended default (good balance of accuracy and speed)
#    30m — high detail, use only for short-range nodes or fast machines
#   200m — fast, for large meshes or limited hardware
MESHCOVERAGE_DEM_RESOLUTION=100

# Optional DSM (surface model including buildings/trees). Leave unset for bare-earth only.
# MESHCOVERAGE_DSM_DIR=./data/dsm

# Maximum analysis radius per node (km).
# The engine automatically limits each node to its link-budget range,
# so raising this only affects nodes that can actually reach further.
# 150 km covers most real-world deployments. Increase to 300 km for
# hilltop ROUTER nodes with high-gain antennas.
MESHCOVERAGE_MAX_RANGE_KM=150.0

# Number of CPU workers for viewshed parallelisation (0 = use all cores)
MESHCOVERAGE_MAX_WORKERS=0

# Receiver height above ground in metres (pedestrian/mobile device)
MESHCOVERAGE_RECEIVER_HEIGHT_M=1.5

# Reference receiver antenna gain in dBi (standard dipole)
MESHCOVERAGE_RECEIVER_GAIN_DBI=2.15

# Minimum link margin to mark a point as "covered" (dB)
# 0 dB = at the sensitivity threshold; increase for more conservative coverage maps
MESHCOVERAGE_MIN_LINK_BUDGET_DB=0.0

# ERP threshold for regulatory warning (dBm) — EU ETSI EN 300-220 limit: +27 dBm
MESHCOVERAGE_ERP_WARNING_DBM=27.0
